# Copiá este archivo a .env y completá los valores. .env está en .gitignore.

# --- Embeddings ---
# Proveedor: "cohere" (API, recomendado para VM chica) | "sentence-transformers" (local)
RAG_EMBEDDING_PROVIDER=cohere

# API key de Cohere (https://dashboard.cohere.com/api-keys)
COHERE_API_KEY=tu-api-key-aca

# (opcional) modelo de Cohere; por defecto embed-multilingual-v3.0
# RAG_COHERE_MODEL=embed-multilingual-v3.0

# --- Indexación ---
# RAG_INDEXER=chroma
# RAG_CHROMA_DIR=chroma_db
# RAG_CHROMA_COLLECTION=documentos
